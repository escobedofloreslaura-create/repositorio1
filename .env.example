# =============================================
# CONFIGURACIÓN DEL PROYECTO LEF PATRIMONIAL
# =============================================
# Copia este archivo y renómbralo a: .env
# Luego llena los valores según las instrucciones

# -----------------------------------------------
# BASE DE DATOS (obligatorio)
# -----------------------------------------------
# SQLite local — deja este valor exactamente así,
# no necesitas instalar nada extra
DATABASE_URL="file:./dev.db"

# -----------------------------------------------
# URL DEL SITIO (obligatorio)
# -----------------------------------------------
# En desarrollo siempre es localhost:3000
NEXT_PUBLIC_URL="http://localhost:3000"

# -----------------------------------------------
# INTELIGENCIA ARTIFICIAL (opcional)
# -----------------------------------------------
# Si no lo pones, el sistema usa respuestas
# automáticas pre-programadas (funciona igual)
# Para obtener tu clave: https://console.anthropic.com
ANTHROPIC_API_KEY=""
